# Playwright e2e — copy to .env.e2e (gitignored) and fill in values

# Production URL (default matches Railway deploy)
E2E_BASE_URL=https://candidatescreen-production.up.railway.app

# Recruiter test account on production (not your personal admin if avoidable)
E2E_EMAIL=you@company.com
E2E_PASSWORD=your-test-password

# Optional: candidate invite token from a published interview (path segment after /i/)
# E2E_INVITE_TOKEN=abc123...

# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/candidate_screen?schema=public"

# Session secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"

# App URL (used for password reset links in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev only: skip database + login to preview all screens (never use in production)
DEV_BYPASS_AUTH=true
